{
  "version": "2.0.0",
  "tasks": [
    {
      "label": ".NET Test with debugger",
      "type": "process",
      "isBackground": true,
      "command": "dotnet",
      "args": ["test"],
      "options": {
        "cwd": "${workspaceFolder}/src/JUS.Tests/",
        "env": {
          "VSTEST_HOST_DEBUG": "1"
        }
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "type": "process",
      "command": "dotnet",
      "args": ["build", "src/JUS.CLI", "-p:RunAnalizers=false"],
      "group": {
        "kind": "build",
        "isDefault": true,
      },
      "problemMatcher": ["$msCompile"],
      "label": "Build"
    },
    {
      "type": "process",
      "command": "dotnet",
      "args": ["test", "src/JUSToolkit.sln"],
      "group": {
        "kind": "test",
        "isDefault": true,
      },
      "problemMatcher": ["$msCompile"],
      "label": "Test"
    },
    {
      "type": "process",
      "command": "dotnet",
      "args": ["run", "build.cs", "--", "--target=Bundle"],
      "problemMatcher": ["$msCompile"],
      "label": "Bundle"
    }
  ]
}
